---
import BaseLayout from '../layouts/BaseLayout.astro';

const lastUpdated = '2026-05-02';
const email = 'nailsonsalon@gmail.com';
---

<BaseLayout
  title="Terms of Service — Nails On Salon"
  description="Terms of Service for nailsonsalon.com — booking, photography, external links, governing law."
>
  <!-- HERO -->
  <section class="bg-bg-tint py-2xl sm:py-3xl">
    <div class="px-5 sm:px-10 max-w-container-xl mx-auto">
      <h1 class="font-display font-light text-display-mobile sm:text-display-desktop text-ink">
        Terms of Service
      </h1>
      <p class="text-body-large text-muted mt-md max-w-2xl">
        Plain-language terms covering use of this website and bookings made through Instagram.
      </p>
    </div>
  </section>

  <!-- CONTENT -->
  <section class="bg-white py-2xl sm:py-3xl">
    <div class="px-5 sm:px-10 max-w-container-xl mx-auto">
      <article class="max-w-2xl space-y-xl text-body-base text-ink leading-relaxed">

        <div>
          <h2 class="font-display font-semibold text-h3-mobile sm:text-h3-desktop text-ink mb-md">
            1. Acceptance
          </h2>
          <p>
            By using this website, you agree to these Terms.
          </p>
        </div>

        <div>
          <h2 class="font-display font-semibold text-h3-mobile sm:text-h3-desktop text-ink mb-md">
            2. About This Website
          </h2>
          <p>
            This website is informational only. Nails On Salon is operated by Tetiana Yaresko,
            a sole proprietor located at 3030 Plaza Bonita Rd, Unit 1336, Suite 117,
            National City, CA 91950.
          </p>
        </div>

        <div>
          <h2 class="font-display font-semibold text-h3-mobile sm:text-h3-desktop text-ink mb-md">
            3. Booking
          </h2>
          <p>
            Appointments are booked exclusively via Instagram Direct Message. Viewing this website
            does not create a booking, reservation, or any obligation to provide services. An
            appointment is confirmed only after we reply to your message and agree on a date and time.
          </p>
        </div>

        <div>
          <h2 class="font-display font-semibold text-h3-mobile sm:text-h3-desktop text-ink mb-md">
            4. Photography
          </h2>
          <p>
            Portfolio photographs displayed on this website show original nail work performed at
            Nails On Salon. If you are depicted in any photograph and would like it removed,
            please contact us at
            <a
              href={`mailto:${email}`}
              class="text-ink underline decoration-brand decoration-2 underline-offset-4 hover:text-muted"
            >{email}</a>
            and we will remove it promptly.
          </p>
        </div>

        <div>
          <h2 class="font-display font-semibold text-h3-mobile sm:text-h3-desktop text-ink mb-md">
            5. Accuracy of Information
          </h2>
          <p>
            We make reasonable efforts to keep service descriptions, prices, and availability current.
            Prices and availability are subject to change without notice and are confirmed at the time
            of booking.
          </p>
        </div>

        <div>
          <h2 class="font-display font-semibold text-h3-mobile sm:text-h3-desktop text-ink mb-md">
            6. External Links
          </h2>
          <p>
            This website links to Instagram and may link to other third-party services. We do not
            control these services and are not responsible for their content, availability, or
            privacy practices.
          </p>
        </div>

        <div>
          <h2 class="font-display font-semibold text-h3-mobile sm:text-h3-desktop text-ink mb-md">
            7. Limitation of Liability
          </h2>
          <p>
            To the fullest extent permitted by law, Nails On Salon is not liable for any indirect,
            incidental, or consequential damages arising from your use of this website.
          </p>
        </div>

        <div>
          <h2 class="font-display font-semibold text-h3-mobile sm:text-h3-desktop text-ink mb-md">
            8. Governing Law
          </h2>
          <p>
            These Terms are governed by the laws of the State of California. Any dispute arising from
            these Terms or your use of this website will be resolved in the state or federal courts
            located in San Diego County, California.
          </p>
        </div>

        <div>
          <h2 class="font-display font-semibold text-h3-mobile sm:text-h3-desktop text-ink mb-md">
            9. Contact
          </h2>
          <p>
            Questions about these Terms:
            <a
              href={`mailto:${email}`}
              class="text-ink underline decoration-brand decoration-2 underline-offset-4 hover:text-muted"
            >{email}</a>.
          </p>
        </div>

        <div class="pt-lg border-t border-border">
          <p class="text-body-small text-muted">
            Last Updated: <time datetime={lastUpdated}>{lastUpdated}</time>
          </p>
        </div>

      </article>
    </div>
  </section>
</BaseLayout>
