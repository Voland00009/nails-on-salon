---
import { Image } from 'astro:assets';
import { getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import InstagramCTA from '../components/InstagramCTA.astro';
import GalleryStrip from '../components/GalleryStrip.astro';
import GoogleMap from '../components/GoogleMap.astro';
import heroImage from '../assets/hero/IMG_3262.JPG';
import studioImage from '../assets/salon/IMG_9975.jpg';

const heroContent = await getEntry('site', 'hero');
const { Content: HeroText } = await heroContent.render();
---
<BaseLayout
  title="Nails On Salon — Premium Nail Studio in National City, CA"
  description="Private nail studio specializing in clean, natural-looking manicures and dry pedicures. Located in National City, CA. Book via Instagram DM."
>
  <!-- HERO -->
  <section class="bg-white">
    <!-- Mobile: photo on top, text below -->
    <!-- Desktop: text 40% left, photo 60% right -->
    <div class="flex flex-col lg:flex-row lg:items-center lg:min-h-[80vh]">

      <!-- Photo (mobile: first, desktop: second via order) -->
      <div class="lg:order-2 lg:w-[60%] overflow-hidden">
        <Image
          src={heroImage}
          alt="Tetiana in her private nail studio with pink 'Hello Gorgeous' neon sign"
          widths={[640, 768, 1024, 1280, 1536]}
          sizes="(min-width: 1280px) 672px, (min-width: 1024px) 576px, 100vw"
          quality={80}
          loading="eager"
          fetchpriority="high"
          class="w-full h-[70vh] lg:h-full object-cover object-center animate-hero-fade"
        />
      </div>

      <!-- Text -->
      <div class="lg:order-1 lg:w-[40%] px-5 sm:px-10 lg:pr-10 lg:pl-0 py-xl lg:py-5xl">
        <div class="mx-auto max-w-container-lg lg:mx-0 lg:ml-auto lg:max-w-[480px] lg:pr-10">
          <!-- Decorative line -->
          <div class="w-[60px] h-[2px] bg-brand mb-lg animate-hero-text" aria-hidden="true"></div>

          <h1 class="font-display font-light text-display-mobile lg:text-display-desktop text-ink animate-hero-text" style="animation-delay: 0.1s">
            Clean Nails.<br />Gentle Touch.
          </h1>

          <div class="mt-md max-w-[400px] text-ink leading-relaxed animate-hero-text" style="animation-delay: 0.15s">
            <HeroText />
          </div>

          <div class="mt-xl animate-hero-text" style="animation-delay: 0.2s">
            <InstagramCTA variant="primary" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES TEASER -->
  <section class="bg-bg-tint py-3xl lg:py-5xl">
    <div class="max-w-container-xl mx-auto px-5 sm:px-10">
      <h2 class="font-display font-light text-h2-mobile lg:text-h2-desktop text-ink mb-2xl">
        Featured Services
      </h2>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-lg">
        <!-- Card 1: Manicure -->
        <a href="/services#manicure" class="group">
          <div class="p-lg border-l-2 border-l-brand rounded-lg bg-white transition-all duration-200 hover:shadow-lg hover:-translate-y-px h-full flex flex-col">
            <h3 class="font-display font-semibold text-h3-mobile lg:text-h3-desktop text-ink">
              Manicure
            </h3>
            <p class="text-brand font-medium mt-1">$45–$65</p>
            <p class="text-muted text-sm mt-1">30–45 min</p>
            <p class="text-muted text-body-small mt-md flex-grow">
              Clean, natural-looking manicures with premium polish and care.
            </p>
          </div>
        </a>

        <!-- Card 2: Pedicure -->
        <a href="/services#pedicure" class="group">
          <div class="p-lg border-l-2 border-l-brand rounded-lg bg-white transition-all duration-200 hover:shadow-lg hover:-translate-y-px h-full flex flex-col">
            <h3 class="font-display font-semibold text-h3-mobile lg:text-h3-desktop text-ink">
              Pedicure
            </h3>
            <p class="text-brand font-medium mt-1">$55–$75</p>
            <p class="text-muted text-sm mt-1">45–60 min</p>
            <p class="text-muted text-body-small mt-md flex-grow">
              Dry pedicures with gentle foot care and relaxation.
            </p>
          </div>
        </a>

        <!-- Card 3: Nail Art -->
        <a href="/services#nail-art" class="group">
          <div class="p-lg border-l-2 border-border rounded-lg bg-white transition-all duration-200 hover:shadow-lg hover:-translate-y-px h-full flex flex-col">
            <h3 class="font-display font-semibold text-h3-mobile lg:text-h3-desktop text-ink">
              Nail Art & Design
            </h3>
            <p class="text-ink font-medium mt-1">Custom Pricing</p>
            <p class="text-muted text-sm mt-1">Varies</p>
            <p class="text-muted text-body-small mt-md flex-grow">
              Custom designs and special nail art commissions.
            </p>
          </div>
        </a>
      </div>

      <div class="text-center mt-2xl">
        <a
          href="/services"
          class="inline-flex items-center justify-center gap-2 font-body font-medium rounded-pill bg-brand text-ink transition-all duration-200 px-8 py-4 text-ui-medium tracking-[0.03em] min-h-[48px] hover:bg-brand-hover hover:-translate-y-px active:translate-y-0"
        >
          View All Services
        </a>
      </div>
    </div>
  </section>

  <!-- GALLERY STRIP -->
  <section class="bg-bg-tint py-3xl lg:py-5xl">
    <div class="max-w-container-xl mx-auto px-5 sm:px-10 mb-2xl">
      <h2 class="font-display font-light text-h2-mobile lg:text-h2-desktop text-ink">
        Our Work
      </h2>
    </div>

    <GalleryStrip />

    <div class="max-w-container-xl mx-auto px-5 sm:px-10 mt-2xl">
      <div class="text-center">
        <a
          href="/portfolio"
          class="inline-flex items-center justify-center gap-2 font-body font-medium text-brand hover:text-brand-hover transition-colors"
        >
          View Full Gallery →
        </a>
      </div>
    </div>
  </section>

  <!-- STUDIO & LOCATION -->
  <section class="bg-bg-tint py-3xl lg:py-5xl">
    <div class="max-w-container-xl mx-auto px-5 sm:px-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-2xl items-center">
        <!-- Photo -->
        <div class="order-2 lg:order-1 rounded-lg overflow-hidden">
          <Image
            src={studioImage}
            alt="Nails On Salon private studio interior with modern design"
            widths={[640, 768, 1024]}
            sizes="(min-width: 1280px) 560px, (min-width: 1024px) 400px, 100vw"
            quality={80}
            loading="lazy"
            class="w-full h-[300px] lg:h-[500px] object-cover"
          />
        </div>

        <!-- Text + Map -->
        <div class="order-1 lg:order-2 flex flex-col gap-lg">
          <div>
            <h2 class="font-display font-light text-h2-mobile lg:text-h2-desktop text-ink">
              Your Private Studio
            </h2>
            <p class="text-muted text-body-small mt-md leading-relaxed">
              Located in the heart of National City, our private studio is designed for personalized care and attention. We focus on clean techniques and natural-looking results in a welcoming environment.
            </p>
          </div>

          <!-- Location Info -->
          <div class="pt-md border-t border-border">
            <p class="font-body font-medium text-ink mb-1">📍 National City, CA</p>
            <p class="text-muted text-body-small">
              3030 Plaza Bonita Rd<br />
              Unit 1336, Suite 117<br />
              National City, CA 91950
            </p>
            <p class="text-muted text-body-small mt-2">
              Phenix Salon Suites at Westfield Plaza Bonita
            </p>
          </div>

          <!-- Map -->
          <div class="h-[300px] rounded-lg overflow-hidden border border-border">
            <GoogleMap />
          </div>

          <!-- CTA -->
          <InstagramCTA variant="secondary" hint="Available for walk-ins and appointments" />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>