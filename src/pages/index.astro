---
import { Image } from 'astro:assets';
import { getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import InstagramCTA from '../components/InstagramCTA.astro';
import GalleryStrip from '../components/GalleryStrip.astro';
import GoogleMap from '../components/GoogleMap.astro';
import heroImage from '../assets/hero/IMG_3262.JPG';
import helloImage from '../assets/hero/IMG_3260.JPG';
import studioImage from '../assets/phenix/IMG_3268.JPG';
import wayfindingDoor from '../assets/hero/IMG_3263.JPG';
import wayfindingHall from '../assets/phenix/IMG_3266.JPG';

const heroContent = await getEntry('site', 'hero');
const { Content: HeroText } = await heroContent.render();
---
<BaseLayout
  title="Nails On Salon — Premium Nail Studio in National City, CA"
  description="Private nail studio specializing in clean, natural-looking manicures and dry pedicures. Located in National City, CA. Book via Instagram DM."
>
  <!-- HERO -->
  <section class="bg-white">
    <!-- Mobile: photo on top, text below -->
    <!-- Desktop: text 40% left, photo 60% right -->
    <div class="flex flex-col lg:flex-row lg:items-center lg:h-[calc(100vh-72px)]">

      <!-- Photo (mobile: first, desktop: second via order) -->
      <div class="lg:order-2 lg:w-[60%] lg:h-full overflow-hidden">
        <Image
          src={heroImage}
          alt="Tetiana in her private nail studio with pink 'Hello Gorgeous' neon sign"
          widths={[640, 768, 1024, 1280, 1536]}
          sizes="(min-width: 1280px) 672px, (min-width: 1024px) 576px, 100vw"
          quality={80}
          loading="eager"
          fetchpriority="high"
          class="w-full h-[70vh] lg:h-full object-cover object-center animate-hero-fade"
        />
      </div>

      <!-- Text -->
      <div class="lg:order-1 lg:w-[40%] px-5 sm:px-10 lg:pr-10 lg:pl-0 py-xl lg:py-5xl">
        <div class="mx-auto max-w-container-lg lg:mx-0 lg:ml-auto lg:max-w-[480px] lg:pr-10">
          <!-- Decorative line -->
          <div class="w-[60px] h-[2px] bg-brand mb-lg animate-hero-text" aria-hidden="true"></div>

          <h1 class="font-display font-light text-display-mobile lg:text-display-desktop text-ink animate-hero-text" style="animation-delay: 0.1s">
            Clean Nails.<br />Gentle Touch.
          </h1>

          <div class="mt-md max-w-[400px] text-ink leading-relaxed animate-hero-text" style="animation-delay: 0.15s">
            <HeroText />
          </div>

          <div class="mt-xl animate-hero-text" style="animation-delay: 0.2s">
            <InstagramCTA variant="primary" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES TEASER -->
  <section class="bg-bg-tint py-2xl lg:py-3xl">
    <div class="max-w-container-xl mx-auto px-5 sm:px-10">
      <h2 class="reveal font-display font-light text-h2-mobile lg:text-h2-desktop text-ink mb-xl text-center lg:text-left">
        Featured Services
      </h2>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-lg">
        <!-- Card 1: Manicure -->
        <a href="/services#manicure" class="group reveal" style="transition-delay: 0.1s">
          <div class="p-lg border-l-2 border-l-brand rounded-lg bg-white transition-all duration-200 hover:shadow-lg hover:-translate-y-px h-full flex flex-col">
            <h3 class="font-display font-semibold text-h3-mobile lg:text-h3-desktop text-ink">
              Manicure
            </h3>
            <p class="text-brand font-medium mt-1">$45–$65</p>
            <p class="text-muted text-sm mt-1">30–45 min</p>
            <p class="text-muted text-body-small mt-md flex-grow">
              Clean, natural-looking manicures with premium polish and care.
            </p>
          </div>
        </a>

        <!-- Card 2: Pedicure -->
        <a href="/services#pedicure" class="group reveal" style="transition-delay: 0.2s">
          <div class="p-lg border-l-2 border-l-brand rounded-lg bg-white transition-all duration-200 hover:shadow-lg hover:-translate-y-px h-full flex flex-col">
            <h3 class="font-display font-semibold text-h3-mobile lg:text-h3-desktop text-ink">
              Pedicure
            </h3>
            <p class="text-brand font-medium mt-1">$55–$75</p>
            <p class="text-muted text-sm mt-1">45–60 min</p>
            <p class="text-muted text-body-small mt-md flex-grow">
              Dry pedicures with gentle foot care and relaxation.
            </p>
          </div>
        </a>

        <!-- Card 3: Nail Art -->
        <a href="/services#nail-art" class="group reveal" style="transition-delay: 0.3s">
          <div class="p-lg border-l-2 border-l-brand rounded-lg bg-white transition-all duration-200 hover:shadow-lg hover:-translate-y-px h-full flex flex-col">
            <h3 class="font-display font-semibold text-h3-mobile lg:text-h3-desktop text-ink">
              Nail Art & Design
            </h3>
            <p class="text-brand font-medium mt-1">Custom Pricing</p>
            <p class="text-muted text-sm mt-1">Varies</p>
            <p class="text-muted text-body-small mt-md flex-grow">
              Custom designs and special nail art commissions.
            </p>
          </div>
        </a>
      </div>

      <div class="reveal text-center mt-xl">
        <a
          href="/services"
          class="inline-flex items-center justify-center gap-2 font-body font-medium rounded-pill bg-brand text-ink transition-all duration-200 px-8 py-4 text-ui-medium tracking-[0.03em] min-h-[48px] hover:bg-brand-hover hover:-translate-y-px active:translate-y-0"
        >
          View All Services
        </a>
      </div>
    </div>
  </section>

  <!-- GALLERY STRIP -->
  <section class="bg-bg-tint py-2xl lg:py-3xl">
    <div class="max-w-container-xl mx-auto px-5 sm:px-10 mb-lg">
      <h2 class="reveal font-display font-light text-h2-mobile lg:text-h2-desktop text-ink text-center lg:text-left">
        Our Work
      </h2>
    </div>

    <GalleryStrip />

    <div class="reveal max-w-container-xl mx-auto px-5 sm:px-10 mt-lg">
      <div class="text-center">
        <a
          href="/gallery"
          class="inline-flex items-center justify-center gap-2 font-body font-medium text-brand hover:text-brand-hover transition-colors"
        >
          View Full Gallery →
        </a>
      </div>
    </div>
  </section>

  <!-- HELLO GORGEOUS -->
  <section class="bg-white py-2xl lg:py-3xl">
    <div class="max-w-container-xl mx-auto px-5 sm:px-10">
      <div class="flex flex-col lg:flex-row lg:items-center gap-xl">

        <!-- Photo (mobile: second, desktop: first via order) -->
        <div class="reveal lg:w-1/2 order-2 lg:order-1">
          <Image
            src={helloImage}
            alt="Tetiana smiling next to her pink 'Hello Gorgeous' neon sign in the studio"
            widths={[640, 768, 1024]}
            sizes="(min-width: 1280px) 560px, (min-width: 1024px) 400px, 100vw"
            quality={80}
            loading="lazy"
            class="w-full rounded-lg"
          />
        </div>

        <!-- Text (mobile: first, desktop: second via order) -->
        <div class="reveal lg:w-1/2 order-1 lg:order-2" style="transition-delay: 0.15s">
          <h2 class="font-display font-light text-display-mobile lg:text-display-desktop neon-glow">
            Hello Gorgeous
          </h2>
          <p class="text-ink text-body-small leading-relaxed mt-md max-w-[460px]">
            Every visit is a personal experience. I take my time with each client to ensure you leave feeling beautiful and confident.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- STUDIO & LOCATION -->
  <section class="bg-bg-tint py-2xl lg:py-3xl">
    <div class="max-w-container-xl mx-auto px-5 sm:px-10">

      <!-- Heading -->
      <div class="mb-xl">
        <h2 class="reveal font-display font-light text-h2-mobile lg:text-h2-desktop text-ink text-center lg:text-left">
          Your Private Studio
        </h2>
        <p class="text-muted text-body-small mt-md leading-relaxed max-w-[600px] text-center lg:text-left mx-auto lg:mx-0">
          Located in the heart of National City, our private studio is designed for personalized care and attention. We focus on clean techniques and natural-looking results in a welcoming environment.
        </p>
      </div>

      <!-- Wayfinding Intro -->
      <div class="reveal mb-lg">
        <h3 class="font-display font-semibold text-h3-mobile lg:text-h3-desktop text-ink text-center lg:text-left max-w-[600px] mx-auto lg:mx-0">
          How to Find Nails On Salon
        </h3>
        <p class="text-muted text-body-small mt-md text-center lg:text-left max-w-[600px] mx-auto lg:mx-0">
          We're inside Phenix Salon Suites at Plaza Bonita. Here's how to get to Suite 117:
        </p>
        <p class="text-muted text-body-small mt-sm text-center lg:text-left max-w-[600px] mx-auto lg:mx-0">
          We have a separate entrance from the parking lot — no need to walk through the mall.
        </p>
      </div>

      <!-- Wayfinding Photos -->
      <div class="reveal mb-xl">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-md">
          <div>
            <div class="aspect-[3/4] rounded-lg overflow-hidden">
              <Image
                src={studioImage}
                alt="Phenix Salon Suites entrance at Westfield Plaza Bonita"
                widths={[480, 768, 1024]}
                sizes="(min-width: 1024px) 380px, 100vw"
                quality={85}
                loading="lazy"
                class="w-full h-full object-cover"
              />
            </div>
            <p class="text-muted text-body-small text-center mt-sm">Find the entrance</p>
          </div>
          <div>
            <div class="aspect-[3/4] rounded-lg overflow-hidden">
              <Image
                src={wayfindingHall}
                alt="Hallway inside Phenix Salon Suites"
                widths={[320, 480, 640]}
                sizes="(min-width: 1024px) 380px, 100vw"
                quality={80}
                loading="lazy"
                class="w-full h-full object-cover"
              />
            </div>
            <p class="text-muted text-body-small text-center mt-sm">Walk through the hall</p>
          </div>
          <div>
            <div class="aspect-[3/4] rounded-lg overflow-hidden">
              <Image
                src={wayfindingDoor}
                alt="Nails On Salon studio door with logo"
                widths={[320, 480, 640]}
                sizes="(min-width: 1024px) 380px, 100vw"
                quality={80}
                loading="lazy"
                class="w-full h-full object-cover"
              />
            </div>
            <p class="text-muted text-body-small text-center mt-sm">Look for our door, Suite 117</p>
          </div>
        </div>
      </div>

      <!-- Map + Address -->
      <div class="reveal grid grid-cols-1 lg:grid-cols-2 gap-lg">
        <div class="h-[280px] lg:h-[360px] rounded-lg overflow-hidden border border-border">
          <GoogleMap />
        </div>
        <div class="flex flex-col justify-center items-center lg:items-start gap-md">
          <div class="flex items-start gap-2 text-body-small justify-center lg:justify-start">
            <svg class="flex-shrink-0 mt-0.5" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M12 2C8.686 2 6 4.686 6 8c0 5.25 6 14 6 14s6-8.75 6-14c0-3.314-2.686-6-6-6z"/>
              <circle cx="12" cy="8" r="2"/>
            </svg>
            <address class="not-italic text-muted text-center lg:text-left">
              3030 Plaza Bonita Rd, Unit 1336, Suite 117<br />
              National City, CA 91950 &mdash; Phenix Salon Suites
            </address>
          </div>
          <InstagramCTA variant="secondary" />
        </div>
      </div>

    </div>
  </section>

  <script>
    const reveals = document.querySelectorAll('.reveal');
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15 }
    );
    reveals.forEach((el) => observer.observe(el));
  </script>
</BaseLayout>