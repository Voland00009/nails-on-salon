---
interface Props {
  title?: string;
  address?: string;
  class?: string;
}

const {
  title = 'Studio Location',
  address = '3030 Plaza Bonita Rd, Unit 1336, Suite 117, National City, CA 91950',
  class: className = '',
} = Astro.props;

const mapSrc = 'https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3858.5879881580986!2d-117.06902570677119!3d32.65689007939736!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x80d951e346ce652d%3A0xfe12c533356e3ef9!2s3030%20Plaza%20Bonita%20Rd%20Suite%201256%2C%20National%20City%2C%20CA%2091950!5e0!3m2!1sen!2sus!4v1775423921703!5m2!1sen!2sus';
---

<iframe
  src={mapSrc}
  width="100%"
  height="100%"
  style="border: 0; min-height: 400px;"
  allowFullScreen=""
  loading="lazy"
  referrerPolicy="no-referrer-when-downgrade"
  title={title}
  class:list={['rounded-lg', className]}
  aria-label={`${title}: ${address}`}
></iframe>
