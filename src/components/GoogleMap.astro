---
interface Props {
  title?: string;
  address?: string;
  class?: string;
}

const {
  title = 'Studio Location',
  address = '3030 Plaza Bonita Rd, Unit 1336, Suite 117, National City, CA 91950',
  class: className = '',
} = Astro.props;

// Embed-URL указывает пином на парковку перед Phenix Salon Suites
// (place_id Champs Sports — у Phenix на Google Maps пин стоит в неправильном месте,
// поэтому используем этот ориентир, чтобы клиенты приезжали туда, куда нужно).
// Шаблон содержит токен __LANG__ в обоих языковых полях pb-формата (!1s<lang>),
// который подменяется на клиенте через navigator.language.
const mapTemplate = 'https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d365.5318450274173!2d-117.06694459638688!3d32.65713573397495!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x80d951fcd58d2e1b%3A0x31769154a8eba39b!2sChamps%20Sports!5e0!3m2!1s__LANG__!2sus!4v1775533636333!5m2!1s__LANG__!2sus';

// SSR-фоллбэк: английский. Используется до выполнения клиентского скрипта
// и в <noscript> при отключённом JS.
const mapSrcEn = mapTemplate.replaceAll('__LANG__', 'en');
---

<iframe
  data-gmap
  data-gmap-template={mapTemplate}
  src={mapSrcEn}
  width="100%"
  height="100%"
  style="border: 0;"
  allowfullscreen
  loading="lazy"
  referrerpolicy="no-referrer-when-downgrade"
  title={title}
  class:list={['rounded-lg', className]}
  aria-label={`${title}: ${address}`}
></iframe>

<script>
  // Локализация Google Maps embed на язык браузера.
  // Embed iframe не умеет авто-детектить язык — параметр зашит в URL при загрузке.
  // SSG-сайт не может прочитать Accept-Language серверно, поэтому подменяем src на клиенте.
  const SUPPORTED = ['en', 'es', 'ru', 'uk', 'fr', 'de', 'it', 'pt', 'zh', 'ja', 'ko', 'vi', 'tl'];
  const raw = (navigator.language || 'en').toLowerCase().split('-')[0];
  const lang = SUPPORTED.includes(raw) ? raw : 'en';

  if (lang !== 'en') {
    document.querySelectorAll<HTMLIFrameElement>('iframe[data-gmap]').forEach((iframe) => {
      const tpl = iframe.dataset.gmapTemplate;
      if (tpl) iframe.src = tpl.replaceAll('__LANG__', lang);
    });
  }
</script>
