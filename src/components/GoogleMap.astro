---
interface Props {
  title?: string;
  address?: string;
  class?: string;
}

const {
  title = 'Studio Location',
  address = '3030 Plaza Bonita Rd, Unit 1336, Suite 117, National City, CA 91950',
  class: className = '',
} = Astro.props;

const mapSrc = 'https://www.google.com/maps/embed?pb=!1m14!1m12!1m3!1d277.02145153841474!2d-117.06704312388115!3d32.657096410591336!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!5e0!3m2!1sru!2sus!4v1775423270926!5m2!1sru!2sus';
---

<iframe
  src={mapSrc}
  width="100%"
  height="100%"
  style="border: 0; min-height: 400px;"
  allowFullScreen=""
  loading="lazy"
  referrerPolicy="no-referrer-when-downgrade"
  title={title}
  class:list={['rounded-lg', className]}
  aria-label={`${title}: ${address}`}
></iframe>
