---
interface Props {
  title?: string;
  address?: string;
  class?: string;
}

const {
  title = 'Studio Location',
  address = '3030 Plaza Bonita Rd, Unit 1336, Suite 117, National City, CA 91950',
  class: className = '',
} = Astro.props;

// Coordinates for National City, CA (approximate location)
const latitude = 32.6736;
const longitude = -117.0836;
const mapSrc = `https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3361.1234567890!2d${longitude}!3d${latitude}!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x80d94c8c8c8c8c8d%3A0x1234567890!2s3030%20Plaza%20Bonita%20Rd!5e0!3m2!1sen!2sus!4v1234567890`;
---

<iframe
  src={mapSrc}
  width="100%"
  height="100%"
  style="border: 0; min-height: 400px;"
  allowFullScreen=""
  loading="lazy"
  referrerPolicy="no-referrer-when-downgrade"
  title={title}
  class:list={['rounded-lg', className]}
  aria-label={`${title}: ${address}`}
></iframe>
