---
interface ImageItem {
  src: any;
  alt: string;
}

interface Props {
  images: ImageItem[];
}

const { images } = Astro.props;
---

<div id="gallery-lightbox">
  <dialog
    id="lightbox-dialog"
    class="lightbox-dialog"
    aria-label="Full-size photo viewer"
  >
    <!-- Main content -->
    <div class="lightbox-content">
      <!-- Image -->
      <img
        id="lightbox-image"
        src=""
        alt=""
        class="lightbox-image"
        loading="eager"
      />

      <!-- Navigation: Previous button -->
      <button
        id="lightbox-prev"
        class="lightbox-button lightbox-nav lightbox-nav--prev"
        aria-label="Previous image"
        type="button"
      >
        <svg class="lightbox-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>

      <!-- Navigation: Next button -->
      <button
        id="lightbox-next"
        class="lightbox-button lightbox-nav lightbox-nav--next"
        aria-label="Next image"
        type="button"
      >
        <svg class="lightbox-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>

      <!-- Close button -->
      <button
        id="lightbox-close"
        class="lightbox-button lightbox-close"
        aria-label="Close photo viewer"
        type="button"
      >
        <svg class="lightbox-close-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>

      <!-- Counter -->
      <div class="lightbox-counter" id="lightbox-counter" aria-live="polite" aria-atomic="true">
        <span id="lightbox-current">1</span>
        <span>/</span>
        <span id="lightbox-total">{images.length}</span>
      </div>
    </div>
  </dialog>
</div>

<style>
  /* CSS Variables */
  :root {
    --lightbox-z-base: 9999;
    --lightbox-z-overlay: 10000;
    --lightbox-button-size: 48px;
    --lightbox-backdrop-color: rgba(28, 16, 24, 0.92);
    --lightbox-button-bg: rgba(255, 255, 255, 0.15);
    --lightbox-button-bg-hover: rgba(255, 255, 255, 0.3);
    --lightbox-counter-font: 'DM Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  }

  /* Dialog styling */
  #lightbox-dialog {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    margin: 0;
    padding: 0;
    border: none;
    background: transparent;
    z-index: var(--lightbox-z-base);
    opacity: 0;
    transition: opacity 0.2s ease-out;
    pointer-events: none;
  }

  #lightbox-dialog::backdrop {
    background: var(--lightbox-backdrop-color);
  }

  #lightbox-dialog[open] {
    opacity: 1;
    pointer-events: auto;
    animation: lightbox-fade 0.3s ease-out;
  }

  #lightbox-dialog[open]::backdrop {
    animation: lightbox-fade 0.3s ease-out;
  }

  @keyframes lightbox-fade {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  /* Content container */
  .lightbox-content {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }

  /* Image */
  .lightbox-image {
    max-width: 90vw;
    max-height: 85vh;
    object-fit: contain;
    animation: lightbox-image-open 0.3s ease-out;
  }

  @keyframes lightbox-image-open {
    from {
      opacity: 0;
      transform: scale(0.9);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  /* Base button style for nav and close */
  .lightbox-button {
    width: var(--lightbox-button-size);
    height: var(--lightbox-button-size);
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--lightbox-button-bg);
    border: none;
    border-radius: 4px;
    color: white;
    cursor: pointer;
    transition: background 0.2s ease;
    z-index: var(--lightbox-z-overlay);
  }

  .lightbox-button:focus-visible {
    outline: 2px solid white;
    outline-offset: 2px;
  }

  @media (hover: hover) {
    .lightbox-button:hover {
      background: var(--lightbox-button-bg-hover);
    }
  }

  /* Navigation buttons */
  .lightbox-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
  }

  .lightbox-nav--prev {
    left: 1rem;
  }

  .lightbox-nav--next {
    right: 1rem;
  }

  .lightbox-nav-icon {
    width: 24px;
    height: 24px;
  }

  /* Close button */
  .lightbox-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
  }

  .lightbox-close-icon {
    width: 24px;
    height: 24px;
  }

  /* Counter */
  .lightbox-counter {
    position: absolute;
    bottom: 1rem;
    left: 50%;
    transform: translateX(-50%);
    color: rgba(255, 255, 255, 0.7);
    font-family: var(--lightbox-counter-font);
    font-size: 14px;
    white-space: nowrap;
    z-index: var(--lightbox-z-overlay);
  }

  /* Disable animations for users with motion sensitivity */
  @media (prefers-reduced-motion: reduce) {
    #lightbox-dialog,
    .lightbox-image,
    .lightbox-nav,
    .lightbox-close {
      animation: none !important;
      transition: none !important;
    }
  }
</style>

<script define:vars={{ imageUrls: images.map((img, idx) => ({ src: img.src, alt: img.alt, idx })) }}>
  class GalleryLightbox {
    constructor(imageData) {
      this.images = imageData;
      this.currentIndex = 0;
      this.isOpen = false;
      this.isSwiping = false;
      this.swipeStartX = 0;
      this.swipeStartY = 0;
      this.swipeOffsetX = 0;

      // Cache DOM elements
      this.dialog = document.getElementById('lightbox-dialog');
      this.imageEl = document.getElementById('lightbox-image');
      this.prevBtn = document.getElementById('lightbox-prev');
      this.nextBtn = document.getElementById('lightbox-next');
      this.closeBtn = document.getElementById('lightbox-close');
      this.currentCounter = document.getElementById('lightbox-current');
      this.totalCounter = document.getElementById('lightbox-total');
      this.lastFocusedElement = null;

      this.setupEventListeners();
      this.setupGridButtons();
    }

    setupEventListeners() {
      // Button click handlers
      this.prevBtn.addEventListener('click', () => this.previousImage());
      this.nextBtn.addEventListener('click', () => this.nextImage());
      this.closeBtn.addEventListener('click', () => this.closeModal());

      // Dialog cancel (ESC key or other close triggers)
      this.dialog.addEventListener('cancel', () => this.closeModal());

      // Keyboard navigation (global, only when dialog is open)
      document.addEventListener('keydown', (e) => this.handleKeyboard(e));

      // Touch/swipe events on image
      this.imageEl.addEventListener('touchstart', (e) => this.handleTouchStart(e));
      this.imageEl.addEventListener('touchmove', (e) => this.handleTouchMove(e));
      this.imageEl.addEventListener('touchend', (e) => this.handleTouchEnd(e));

      // Focus trap (Tab within dialog)
      this.dialog.addEventListener('keydown', (e) => this.handleFocusTrap(e));
    }

    setupGridButtons() {
      // Attach click handlers to gallery grid image buttons
      // These will be created by GalleryGrid component
      const gridButtons = document.querySelectorAll('#gallery-grid button');
      gridButtons.forEach((btn, idx) => {
        btn.addEventListener('click', () => this.openImage(idx));
      });
    }

    openImage(index) {
      if (index < 0 || index >= this.images.length) return;

      this.currentIndex = index;
      this.lastFocusedElement = document.activeElement;

      // Load and display image
      this.loadImage(this.currentIndex);

      // Show dialog
      this.dialog.showModal();
      this.isOpen = true;
      document.body.style.overflow = 'hidden';

      // Focus close button for accessibility
      setTimeout(() => this.closeBtn.focus(), 0);

      // Preload adjacent images
      this.preloadAdjacentImages();
    }

    closeModal() {
      if (!this.isOpen) return;

      this.dialog.close();
      this.isOpen = false;
      document.body.style.overflow = '';

      // Return focus to element that opened lightbox
      if (this.lastFocusedElement) {
        setTimeout(() => this.lastFocusedElement.focus(), 0);
      }
    }

    loadImage(index) {
      if (index < 0 || index >= this.images.length) return;

      this.currentIndex = index;
      const image = this.images[index];

      // Handle Astro image import objects
      const imageUrl = typeof image.src === 'object' ? image.src.src : image.src;

      this.imageEl.src = imageUrl;
      this.imageEl.alt = image.alt;
      this.currentCounter.textContent = index + 1;
    }

    nextImage() {
      const nextIndex = (this.currentIndex + 1) % this.images.length;
      this.loadImage(nextIndex);
      this.preloadAdjacentImages();
    }

    previousImage() {
      const prevIndex = (this.currentIndex - 1 + this.images.length) % this.images.length;
      this.loadImage(prevIndex);
      this.preloadAdjacentImages();
    }

    preloadAdjacentImages() {
      const prev = (this.currentIndex - 1 + this.images.length) % this.images.length;
      const next = (this.currentIndex + 1) % this.images.length;

      const prevUrl = typeof this.images[prev].src === 'object'
        ? this.images[prev].src.src
        : this.images[prev].src;
      const nextUrl = typeof this.images[next].src === 'object'
        ? this.images[next].src.src
        : this.images[next].src;

      // Preload by creating image objects (browser cache)
      new Image().src = prevUrl;
      new Image().src = nextUrl;
    }

    handleKeyboard(e) {
      if (!this.isOpen) return;

      if (e.key === 'ArrowLeft') {
        e.preventDefault();
        this.previousImage();
      } else if (e.key === 'ArrowRight') {
        e.preventDefault();
        this.nextImage();
      } else if (e.key === 'Escape') {
        e.preventDefault();
        this.closeModal();
      }
    }

    handleFocusTrap(e) {
      if (e.key !== 'Tab') return;

      // Cycle focus through: close → prev → next
      const focusableElements = [
        this.closeBtn,
        this.prevBtn,
        this.nextBtn
      ];

      const currentIndex = focusableElements.indexOf(document.activeElement);
      let nextIndex;

      if (e.shiftKey) {
        // Shift+Tab: backwards
        nextIndex = currentIndex - 1 < 0 ? focusableElements.length - 1 : currentIndex - 1;
      } else {
        // Tab: forwards
        nextIndex = currentIndex + 1 >= focusableElements.length ? 0 : currentIndex + 1;
      }

      e.preventDefault();
      focusableElements[nextIndex].focus();
    }

    handleTouchStart(e) {
      if (e.touches.length !== 1) return;

      this.isSwiping = true;
      this.swipeStartX = e.touches[0].clientX;
      this.swipeStartY = e.touches[0].clientY;
      this.swipeOffsetX = 0;
    }

    handleTouchMove(e) {
      if (!this.isSwiping || e.touches.length !== 1) return;

      this.swipeOffsetX = e.touches[0].clientX - this.swipeStartX;

      // Detect if swipe is horizontal (prevent vertical scroll)
      const yDiff = Math.abs(e.touches[0].clientY - this.swipeStartY);
      const xDiff = Math.abs(this.swipeOffsetX);

      if (xDiff > yDiff) {
        e.preventDefault();
      }
    }

    handleTouchEnd(e) {
      if (!this.isSwiping) return;

      this.isSwiping = false;
      const threshold = 50;

      // Swipe left (negative X) = next image
      if (this.swipeOffsetX < -threshold) {
        this.nextImage();
      }
      // Swipe right (positive X) = previous image
      else if (this.swipeOffsetX > threshold) {
        this.previousImage();
      }

      this.swipeOffsetX = 0;
    }
  }

  // Initialize when DOM is ready
  function initGalleryLightbox() {
    const imageData = imageUrls; // From define:vars
    const lightbox = new GalleryLightbox(imageData);

    // Expose to global scope so GalleryGrid can call it
    window.galleryLightbox = lightbox;
  }

  // Run initialization
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initGalleryLightbox);
  } else {
    initGalleryLightbox();
  }
</script>
