---
interface Props {
  title: string;
  price: number;
  priceMax?: number;
  duration?: string;
  includes?: string;
  note?: string;
}

const { title, price, priceMax, duration, includes, note } = Astro.props;
const priceDisplay = priceMax ? `$${price}–${priceMax}` : `$${price}`;
const priceAndDuration = duration ? `${priceDisplay} · ${duration}` : priceDisplay;
---

<div class="flex flex-col sm:flex-row sm:justify-between py-md">
  <span class="text-ink">
    {title}
    {includes && <span class="block text-muted text-sm mt-0.5">{includes}</span>}
    {note && <span class="block text-muted text-sm italic mt-0.5">{note}</span>}
  </span>
  <span class="font-medium text-ink text-sm sm:text-base flex-shrink-0 mt-1 sm:mt-0">
    {priceAndDuration}
  </span>
</div>
