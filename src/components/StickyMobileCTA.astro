---
import { instagramDmUrl } from '../config/site';
---

<div
  id="sticky-mobile-cta"
  class="fixed bottom-5 inset-x-0 z-40 flex justify-center lg:hidden"
  aria-hidden="true"
>
  <a
    href={instagramDmUrl}
    target="_blank"
    rel="noopener noreferrer"
    tabindex="-1"
    class="inline-flex items-center gap-2 font-body font-medium rounded-pill bg-brand text-ink px-8 py-4 text-ui-medium tracking-[0.03em] min-h-[48px] hover:bg-brand-hover active:scale-[0.97] transition-colors duration-200"
    style="box-shadow: 0 4px 20px rgba(255, 194, 209, 0.7);"
  >
    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
    </svg>
    Book via Instagram
  </a>
</div>

<style>
  #sticky-mobile-cta {
    transform: translateY(calc(100% + 20px));
    transition: transform 0.3s ease-out;
  }
  #sticky-mobile-cta.is-visible {
    transform: translateY(0);
  }
</style>

<script>
  const bar = document.getElementById('sticky-mobile-cta') as HTMLElement | null;
  const link = bar?.querySelector('a');
  const SCROLL_THRESHOLD = 100;
  let lastScrollY = window.scrollY;
  let isVisible = false;
  let footerVisible = false;

  function showBar() {
    if (isVisible || footerVisible) return;
    isVisible = true;
    bar?.classList.add('is-visible');
    bar?.removeAttribute('aria-hidden');
    link?.removeAttribute('tabindex');
  }

  function hideBar() {
    if (!isVisible) return;
    isVisible = false;
    bar?.classList.remove('is-visible');
    bar?.setAttribute('aria-hidden', 'true');
    link?.setAttribute('tabindex', '-1');
  }

  window.addEventListener('scroll', () => {
    const currentScrollY = window.scrollY;

    if (currentScrollY < SCROLL_THRESHOLD) {
      hideBar();
    } else if (currentScrollY > lastScrollY) {
      if (!footerVisible) showBar();
    } else {
      hideBar();
    }

    lastScrollY = currentScrollY;
  }, { passive: true });

  const footer = document.querySelector('footer');
  if (footer) {
    new IntersectionObserver(([entry]) => {
      footerVisible = entry.isIntersecting;
      if (footerVisible) hideBar();
    }, { threshold: 0 }).observe(footer);
  }
</script>
