---
import { Image } from 'astro:assets';
import img3209 from '../assets/work/IMG_3209.jpg';
import img1043 from '../assets/work/IMG_1043.JPG';
import img3148 from '../assets/work/IMG_3148.jpg';
import img3206 from '../assets/work/IMG_3206.jpg';
import img3213 from '../assets/work/IMG_3213.jpg';
import img4349 from '../assets/work/IMG_4349.JPG';
const photos = [
  { src: img3209, alt: 'Long almond nails in glossy red gel polish on a black Louis Vuitton bag' },
  { src: img1043, alt: "Long almond French manicures with white tips, in front of the studio's pink 'Hello Gorgeous' neon sign" },
  { src: img3148, alt: 'Almond nails with a black lace pattern over a sheer nude base' },
  { src: img3206, alt: 'Long almond nails in solid bright red gel polish' },
  { src: img4349, alt: 'Short almond nails with a soft pink-nude French manicure' },
  { src: img3213, alt: 'Square nails in glossy magenta-pink gel polish' },
];
---

<div class="scroll-snap-x-mandatory flex gap-3 overflow-x-auto lg:overflow-visible px-5 sm:px-10 max-w-container-xl mx-auto">
  {photos.map((photo) => (
    <div class="scroll-snap-start flex-none w-[220px] sm:w-[260px] lg:flex-1 lg:min-w-0 aspect-[4/5] rounded-lg overflow-hidden">
      <Image
        src={photo.src}
        alt={photo.alt}
        widths={[280, 360, 480]}
        sizes="(min-width: 1024px) 200px, 260px"
        class="w-full h-full object-cover transition-transform duration-300 hover:scale-[1.02]"
        loading="lazy"
      />
    </div>
  ))}
</div>
